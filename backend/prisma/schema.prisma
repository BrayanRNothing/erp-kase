generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String
  role        Role     @default(USER)
  
  // Team functionality
  parentId    String?   // Si es miembro, ID del dueño (owner)
  companyName String?   // Si es dueño, nombre de la empresa
  companyLogo String?   // Si es dueño, URL del logo de la empresa
  teamCode    String?   @unique // Código fijo para unirse al clan/equipo
  parent      User?     @relation("UserToUser", fields: [parentId], references: [id])
  children    User[]    @relation("UserToUser")
  
  // Relations
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cards     Card[]
  movements Movement[]
  invoices  Invoice[]
  budgets   Budget[]
  clients   Client[]
  documents Document[]
  activityLogs ActivityLog[]
  expectedExpenses ExpectedExpense[]
  receivables Receivable[]
  payables Payable[]
  inventoryItems InventoryItem[]
  inventoryMovements InventoryMovement[]

}

enum Role {
  USER
  ADMIN
}

model Card {
  id          String     @id @default(uuid())
  name        String     // ej. "Cuenta Principal", "Tarjeta de Crédito X"
  type        CardType   @default(DEBIT)
  balance     Decimal    @default(0.00) @db.Decimal(12, 2)
  currency    String     @default("USD")
  lastFour    String?    // Últimos 4 dígitos para UI
  color       String?    // Color de la tarjeta (hex o tailwind class)
  
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  movements   Movement[]
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum CardType {
  CREDIT
  DEBIT
  CASH
}

model Movement {
  id          String       @id @default(uuid())
  type        MovementType // INCOME (Ingreso), EXPENSE (Gasto)
  amount      Decimal      @db.Decimal(12, 2)
  description String
  category    String?      // Categoría del movimiento (opcional)
  date        DateTime     @default(now())
  
  // Condición Estricta: Obligatoriamente vinculado a una tarjeta
  cardId      String
  card        Card         @relation(fields: [cardId], references: [id], onDelete: Cascade)
  
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

enum MovementType {
  INCOME
  EXPENSE
}

// Módulo de Facturación (Aislado)
model Invoice {
  id            String          @id @default(uuid())
  invoiceNumber String          @unique
  clientName    String
  clientEmail   String?
  totalAmount   Decimal         @db.Decimal(12, 2)
  status        InvoiceStatus   @default(DRAFT)
  issueDate     DateTime        @default(now())
  
  userId        String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  items         InvoiceItem[]
  
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model InvoiceItem {
  id          String   @id @default(uuid())
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(12, 2)
  
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  CANCELLED
}

model Budget {
  id        String   @id @default(uuid())
  category  String
  limit     Decimal  @db.Decimal(12, 2)
  spent     Decimal  @default(0.00) @db.Decimal(12, 2)
  period    String   @default("monthly")
  color     String?  // CSS class name for color display
  
  userId    String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  address   String?
  type      String   @default("client") // "client" o "provider"
  
  userId    String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  inventoryItems InventoryItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Document {
  id        String   @id @default(uuid())
  name      String
  category  String
  type      String?  // MIME type (application/pdf, image/png, etc.)
  size      Int
  fileUrl   String?
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id          String   @id @default(uuid())
  type        String
  title       String
  description String?
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
}

model ExpectedExpense {
  id          String   @id @default(uuid())
  description String
  amount      Decimal  @db.Decimal(12, 2)
  category    String
  dueDate     DateTime
  status      String   @default("pending") // pending, paid
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Receivable {
  id          String   @id @default(uuid())
  clientName  String
  description String
  amount      Decimal  @db.Decimal(12, 2)
  dueDate     DateTime
  status      String   @default("pending") // pending, paid
  paidDate    DateTime?
  cardId      String?
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Payable {
  id          String   @id @default(uuid())
  providerName String
  description String
  amount      Decimal  @db.Decimal(12, 2)
  dueDate     DateTime
  status      String   @default("pending") // pending, paid
  paidDate    DateTime?
  cardId      String?
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InventoryItem {
  id              String   @id @default(uuid())
  name            String   // Nombre del químico / producto
  containerType   String   // "Bote", "Tina", "Tambor", "Cubeta", etc.
  capacity        Decimal  @db.Decimal(12, 2) // cantidad que contiene el bote
  unit            String   // "L", "kg", "ml", "g"
  stock           Int      @default(0) // cantidad física de botes
  minStock        Int      @default(0) // Alerta de stock bajo
  
  category        String   @default("Materia Prima")
  color           String   @default("#3B82F6")
  location        String?
  unitCost        Decimal  @default(0.00) @db.Decimal(12, 2)
  
  providerId      String?
  provider        Client?  @relation(fields: [providerId], references: [id])
  
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  movements       InventoryMovement[]
  
  recipesAsFinal  RecipeIngredient[] @relation("FinalProduct")
  recipesAsRaw    RecipeIngredient[] @relation("RawMaterial")
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model InventoryMovement {
  id              String   @id @default(uuid())
  type            String   // "IN", "OUT", "ADJUST"
  quantity        Int
  reason          String
  date            DateTime @default(now())
  
  itemId          String
  item            InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RecipeIngredient {
  id              String   @id @default(uuid())
  quantity        Decimal  @db.Decimal(12, 2) // Cantidad de materia prima requerida
  
  finalProductId  String
  finalProduct    InventoryItem @relation("FinalProduct", fields: [finalProductId], references: [id], onDelete: Cascade)
  
  rawMaterialId   String
  rawMaterial     InventoryItem @relation("RawMaterial", fields: [rawMaterialId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())
}
